{
    "layout": {
        "type": "layout",
        "pages": ["panel", "menu"],
        "panel": {
            "type": "page",
            "title": "Panneau",
            "sections": ["panel-appear", "panel-behave"]
        },
        "menu": {
            "type": "page",
            "title": "Menu",
            "sections": ["menu-layout", "menu-behave"]
        },
        "panel-appear": {
            "type": "section",
            "title": "Apparence",
            "keys": ["menu-custom", "menu-icon", "menu-icon-size", "menu-label"]
        },
        "panel-behave": {
            "type": "section",
            "title": "Comportement",
            "keys": ["overlay-key", "activate-on-hover", "force-show-panel", "enable-animation"]
        },
        "menu-layout": {
            "type": "section",
            "title": "Disposition et contenu",
            "keys": ["show-category-icons", "show-application-icons", "favbox-show", "show-places", "show-recents"]
        },
        "menu-behave": {
            "type": "section",
            "title": "Comportement",
            "keys": ["category-hover", "enable-autoscroll", "search-filesystem"]
        }
    },
    "overlay-key": {
        "type": "keybinding",
        "description": "Raccourci clavier pour ouvrir et fermer le menu",
        "default": "Super_L::Super_R",
        "value": "Super_L::Super_R"
    },
    "menu-custom": {
        "type": "switch",
        "default": false,
        "description": "Utiliser une icône et un libellé personnalisés",
        "value": true
    },
    "menu-icon": {
        "type": "iconfilechooser",
        "default": "cinnamon-symbolic",
        "description": "Icône",
        "default_icon": "cinnamon-symbolic",
        "dependency": "menu-custom",
        "value": "nix-snowflake-white"
    },
    "menu-icon-size": {
        "type": "spinbutton",
        "default": 32,
        "min": 16,
        "max": 96,
        "step": 1,
        "units": "px",
        "description": "Taille de l'icône",
        "dependency": "menu-custom",
        "value": 24.0
    },
    "menu-label": {
        "type": "entry",
        "default": "Menu",
        "description": "Texte",
        "dependency": "menu-custom",
        "value": "Menu"
    },
    "show-category-icons": {
        "type": "switch",
        "default": true,
        "description": "Afficher les icônes de catégorie",
        "value": true
    },
    "show-application-icons": {
        "type": "switch",
        "default": true,
        "description": "Afficher les icônes d'application",
        "value": true
    },
    "favbox-show": {
        "type": "switch",
        "default": true,
        "description": "Afficher les favoris et les boutons de session",
        "value": true
    },
    "show-places": {
        "type": "switch",
        "default": true,
        "description": "Afficher les signets et les emplacements",
        "value": false
    },
    "show-recents": {
        "type": "switch",
        "default": true,
        "description": "Afficher les éléments récents",
        "value": false
    },
    "category-hover": {
        "type": "switch",
        "default": true,
        "description": "Changer de catégorie au survol",
        "value": false
    },
    "enable-autoscroll": {
        "type": "switch",
        "default": true,
        "description": "Activer le défilement automatique",
        "value": false
    },
    "search-filesystem": {
        "type": "switch",
        "default": false,
        "description": "Activer la recherche de fichiers",
        "value": false
    },
    "force-show-panel": {
        "type": "switch",
        "default": true,
        "description": "Forcer l'affichage du panneau à l'ouverture du menu",
        "value": true
    },
    "activate-on-hover": {
        "type": "switch",
        "default": false,
        "description": "Ouvrir le menu au survol de la souris",
        "value": false
    },
    "enable-animation": {
        "type": "switch",
        "default": false,
        "description": "Utiliser les animations du menu",
        "value": false
    }
}